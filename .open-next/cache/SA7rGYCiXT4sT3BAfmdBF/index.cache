{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.09zddjkbdep5a.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0fbmbgk_sr9f_.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0vunv5z.dftn8.js\"/><script src=\"/_next/static/chunks/0s8yf28e-gaog.js\" async=\"\"></script><script src=\"/_next/static/chunks/07lhk_q6pmm3r.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0r5ija2_qylhu.js\" async=\"\"></script><script src=\"/_next/static/chunks/0lftvpbavdbmj.js\" async=\"\"></script><script src=\"/_next/static/chunks/0dbhjjzl8qfwv.js\" async=\"\"></script><script src=\"/_next/static/chunks/0lm.6r~dol8pb.js\" async=\"\"></script><script src=\"/_next/static/chunks/0g6ba..lh_xyp.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>請求書PDF生成</title><meta name=\"description\" content=\"インボイス対応の請求書PDFをワンクリックで生成\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/icon.png?icon.0n5_rrgpkiq2r.png\" sizes=\"453x340\" type=\"image/png\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-gray-50\"><header class=\"bg-white border-b border-gray-200 sticky top-0 z-10\"><div class=\"max-w-6xl mx-auto px-4 py-3 flex items-center justify-between\"><h1 class=\"text-base font-bold text-gray-900\">請求書PDF生成</h1><div class=\"flex items-center gap-3\"><span class=\"hidden sm:inline text-xs text-gray-400\">消費税10%（インボイス対応）</span></div></div></header><main class=\"max-w-6xl mx-auto px-4 py-6\"><form><div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\"><div class=\"lg:col-span-2 order-2 lg:order-1 bg-white rounded-xl shadow-sm border border-gray-200 p-6\"><div class=\"space-y-6\"><section><h3 class=\"text-sm font-bold text-gray-800 border-b pb-1 mb-3\">基本情報</h3><div class=\"grid grid-cols-3 gap-3\"><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">番号</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"INV-2024-0001\" name=\"invoiceNumber\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">発行日</label><input type=\"date\" class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" name=\"issueDate\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">支払期限 / 有効期限</label><input type=\"date\" class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" name=\"dueDate\"/></div></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">件名（任意）</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"例：2026年5月分システム保守業務\" name=\"subject\"/></div></section><section><div class=\"flex items-center justify-between border-b pb-1 mb-3\"><h3 class=\"text-sm font-bold text-gray-800\">取引先情報</h3></div><div class=\"grid grid-cols-2 gap-3\"><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">取引先名 *</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"○○株式会社\" name=\"clientName\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">担当者名</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"山田 太郎\" name=\"clientContact\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">郵便番号</label><div><div class=\"flex gap-1.5\"><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"100-0001\" name=\"clientPostal\"/><button type=\"button\" class=\"shrink-0 rounded border border-gray-300 bg-gray-50 px-2.5 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-100 disabled:opacity-50\">検索</button></div></div></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">担当部署</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"経理部\" name=\"clientDept\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">住所</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent col-span-2\" placeholder=\"東京都千代田区...\" name=\"clientAddress\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">電話番号</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"03-0000-0000\" name=\"clientTel\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">メールアドレス</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"info@example.com\" name=\"clientEmail\"/></div></div></section><section><div class=\"flex items-center justify-between border-b pb-1 mb-3\"><h3 class=\"text-sm font-bold text-gray-800\">発行者情報</h3></div><div class=\"grid grid-cols-2 gap-3\"><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">会社名 *</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"自社名\" name=\"issuerName\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">電話番号</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"03-0000-0000\" name=\"issuerTel\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">郵便番号</label><div><div class=\"flex gap-1.5\"><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"150-0001\" name=\"issuerPostal\"/><button type=\"button\" class=\"shrink-0 rounded border border-gray-300 bg-gray-50 px-2.5 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-100 disabled:opacity-50\">検索</button></div></div></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">メールアドレス</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"info@example.com\" name=\"issuerEmail\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">住所</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"東京都渋谷区...\" name=\"issuerAddress\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">インボイス登録番号</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"T1234567890123\" name=\"issuerInvoiceNumber\"/></div></div></section><section><h3 class=\"text-sm font-bold text-gray-800 border-b pb-1 mb-3\">明細</h3><div class=\"overflow-x-auto\"><table class=\"w-full text-xs border-collapse\"><thead><tr class=\"bg-gray-100 text-gray-600\"><th class=\"text-left px-2 py-2 font-medium w-[38%]\">品目・内容</th><th class=\"text-right px-2 py-2 font-medium w-[10%]\">数量</th><th class=\"text-left px-2 py-2 font-medium w-[8%]\">単位</th><th class=\"text-right px-2 py-2 font-medium w-[15%]\">単価</th><th class=\"text-right px-2 py-2 font-medium w-[18%]\">金額</th><th class=\"w-[11%]\"></th></tr></thead><tbody><tr class=\"border-b border-gray-100\"><td class=\"px-1 py-1\"><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"デザイン制作費\" name=\"items.0.description\"/></td><td class=\"px-1 py-1\"><input type=\"number\" class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-right\" min=\"0\" name=\"items.0.quantity\"/></td><td class=\"px-1 py-1\"><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"式\" name=\"items.0.unit\"/></td><td class=\"px-1 py-1\"><input type=\"number\" class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-right\" min=\"0\" name=\"items.0.unitPrice\"/></td><td class=\"px-2 py-1 text-right font-medium text-gray-700\">¥<!-- -->0</td><td class=\"px-1 py-1 text-center\"><button type=\"button\" disabled=\"\" class=\"text-red-400 hover:text-red-600 disabled:opacity-30 px-2\">✕</button></td></tr></tbody></table></div><button type=\"button\" class=\"mt-2 text-xs text-blue-600 hover:text-blue-800 flex items-center gap-1\"><span class=\"text-base leading-none\">+</span> 明細を追加</button></section><section><h3 class=\"text-sm font-bold text-gray-800 border-b pb-1 mb-3\">振込先</h3><div class=\"grid grid-cols-3 gap-3\"><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">銀行名</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"○○銀行\" name=\"bankName\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">支店名</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"渋谷支店\" name=\"bankBranch\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">口座種別</label><select name=\"accountType\" class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"><option value=\"普通\">普通</option><option value=\"当座\">当座</option></select></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">口座番号</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"1234567\" name=\"accountNumber\"/></div><div><label class=\"block text-xs font-medium text-gray-600 mb-1\">口座名義</label><input class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"ユウゲンカイシャ マルマル\" name=\"accountHolder\"/></div></div></section><section><div class=\"flex items-center justify-between border-b pb-1 mb-3\"><h3 class=\"text-sm font-bold text-gray-800\">備考</h3></div><textarea name=\"notes\" rows=\"3\" class=\"w-full rounded border border-gray-300 px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\" placeholder=\"振込手数料はご負担ください。\"></textarea></section></div></div><div class=\"order-1 lg:order-2 space-y-4\"><div class=\"bg-white rounded-xl shadow-sm border border-gray-200 p-4\"><h2 class=\"text-sm font-semibold text-gray-700 mb-3\">書類の種類</h2><div class=\"flex gap-1\"><button type=\"button\" class=\"flex-1 text-xs font-medium py-1.5 rounded border transition-colors bg-white text-gray-600 border-gray-300 hover:bg-gray-50\">見積書</button><button type=\"button\" class=\"flex-1 text-xs font-medium py-1.5 rounded border transition-colors bg-gray-800 text-white border-gray-800\">請求書</button><button type=\"button\" class=\"flex-1 text-xs font-medium py-1.5 rounded border transition-colors bg-white text-gray-600 border-gray-300 hover:bg-gray-50\">領収書</button></div></div><div class=\"bg-white rounded-xl shadow-sm border border-gray-200 p-4\"><div><div class=\"flex items-center justify-between mb-3\"><h2 class=\"text-sm font-semibold text-gray-700\">テンプレート選択</h2><div class=\"flex items-center gap-1.5\"><button type=\"button\" disabled=\"\" class=\"w-6 h-6 flex items-center justify-center rounded border border-gray-300 text-gray-500 hover:bg-gray-50 disabled:opacity-30 text-xs\">‹</button><span class=\"text-xs text-gray-400\">1<!-- --> / <!-- -->2</span><button type=\"button\" class=\"w-6 h-6 flex items-center justify-center rounded border border-gray-300 text-gray-500 hover:bg-gray-50 disabled:opacity-30 text-xs\">›</button></div></div><div class=\"grid grid-cols-3 gap-3\"><button type=\"button\" class=\"text-left rounded-lg border-2 overflow-hidden transition-all border-blue-600 ring-2 ring-blue-200\"><div class=\"bg-white p-2 border border-gray-300 text-[7px] h-28 overflow-hidden\"><div class=\"text-center font-bold text-sm border-b border-gray-800 pb-1 mb-1\">請 求 書</div><div class=\"flex gap-2 mb-1\"><div class=\"flex-1 text-[6px]\"><div class=\"font-bold border-b border-gray-800\">○○株式会社</div></div><div class=\"flex-1 text-right text-[6px] font-bold\">発行者名</div></div><div class=\"border border-gray-800 p-1 text-[6px] flex justify-between mb-1\"><span>ご請求金額 ¥XXX,XXX</span><span>期限：XX月XX日</span></div><div class=\"flex bg-gray-800 text-white text-[5px] px-0.5\"><span class=\"flex-1\"># 品目</span><span>金額</span></div></div><div class=\"p-2 bg-white\"><div class=\"flex items-center gap-1.5\"><span class=\"w-3 h-3 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0\"><svg class=\"w-2 h-2 text-white\" viewBox=\"0 0 8 8\" fill=\"currentColor\"><path d=\"M6.41 1L3 4.41 1.59 3 .5 4.09 3 6.5 7.5 2z\"></path></svg></span><span class=\"text-xs font-semibold text-gray-800\">クラシック</span></div><p class=\"text-[10px] text-gray-500 mt-0.5\">伝統的な罫線スタイル。フォーマルな取引に。</p></div></button><button type=\"button\" class=\"text-left rounded-lg border-2 overflow-hidden transition-all border-gray-200 hover:border-gray-400\"><div class=\"bg-white text-[7px] h-28 overflow-hidden\"><div class=\"bg-blue-700 text-white p-2 flex justify-between items-end\"><span class=\"text-sm font-bo